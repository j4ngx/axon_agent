# =============================================================================
# Axon — Secrets Configuration
# =============================================================================
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# All non-secret settings live in config.yml (version-controlled).
# Only API keys, tokens, and credentials belong here.
# =============================================================================

# Telegram bot token obtained from @BotFather
TELEGRAM_BOT_TOKEN="REPLACE_WITH_YOUR_BOT_TOKEN"

# Comma-separated list of Telegram user IDs allowed to interact with Axon
TELEGRAM_ALLOWED_USER_IDS="REPLACE_WITH_YOUR_USER_ID"

# Groq API key — primary LLM backend (https://console.groq.com)
GROQ_API_KEY="REPLACE_WITH_YOUR_GROQ_KEY"

# OpenRouter API key — fallback LLM backend (https://openrouter.ai)
OPENROUTER_API_KEY="REPLACE_WITH_YOUR_OPENROUTER_KEY"

# Google Cloud service account credentials (for future tools, optional)
GOOGLE_APPLICATION_CREDENTIALS="./service-account.json"
